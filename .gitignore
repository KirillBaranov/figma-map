# Compiled binary
/figma-map

# GoReleaser output
/dist/

# Release-only build artifacts (built + zipped/checksummed in CI, see
# release.yml) — untracked copies of these in the working tree make
# goreleaser refuse to release ("git is in a dirty state").
/figma-map-plugin/
/figma-map-plugin.zip
/figma-map-plugin.zip.sha256
/figma-map-backend_*

# Generated artifacts (regenerated by scan/bind)
/catalog/
/figma-map.binding.yaml

# Local config (may contain machine-specific paths)
/figma-map.yaml

# Secrets
.env

# OS
.DS_Store

# Benchmark working dir (regenerable) + scorer binary
/bench/work/
/bin-bench

# Default screenshot/render output (see defaultOutPath in internal/service)
/.figma-map/out/

# Locally-built e2e install-test fixtures (see test/e2e/build-fixtures.sh)
/test/e2e/fixtures/
